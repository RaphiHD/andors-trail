        , { "text":"1/1 andor:914  (Search for Andor - I visited my new residence on the top of Mt. Galmore. There I would help the people of Dhayavar as a hero and protect them from villains. Or would I become a villain myself? We'll see.)", "nextPhraseID":"dbg_scores_10", "requires":[{ "requireType":"questProgress", "requireID":"andor", "value":914 }] } , { "text":"0/4 vacor:60  (Missing pieces - I have killed Unzel and told Vacor about the deed.)", "nextPhraseID":"dbg_scores_10", "requires":[{ "requireType":"questProgress", "requireID":"vacor", "value":60 }] } , { "text":"4/4 vacor:61  (Missing pieces - I have killed Vacor and told Unzel about the deed.)", "nextPhraseID":"dbg_scores_10", "requires":[{ "requireType":"questProgress", "requireID":"vacor", "value":61 }] } , { "text":"4/4 bonemeal:100  (Disallowed substance - I have brought the bones to Thoronir. He is now able to supply me with bonemeal potions.)", "nextPhraseID":"dbg_scores_10", "requires":[{ "requireType":"questProgress", "requireID":"bonemeal", "value":100 }] } , { "text":"0/4 bonemeal:110  (Disallowed substance - I have brought the bones to Thoronir. Of course he wouldn't produce any bonemeal potion from them though, since Lord Geomyr has banned their use.)", "nextPhraseID":"dbg_scores_10", "requires":[{ "requireType":"questProgress", "requireID":"bonemeal", "value":110 }] } , { "text":"0/3 guynmart:210  (Roses - Lovis prepared a surprise for me east of the castle.)", "nextPhraseID":"dbg_scores_10", "requires":[{ "requireType":"questProgress", "requireID":"guynmart", "value":210 }] } , { "text":"3/3 guynmart:211  (Roses - Then I took my leave of Unkorh.)", "nextPhraseID":"dbg_scores_10", "requires":[{ "requireType":"questProgress", "requireID":"guynmart", "value":211 }] } , { "text":"0/4 kaverin:21  (Old friends? - I have declined to help Kaverin.)", "nextPhraseID":"dbg_scores_10", "requires":[{ "requireType":"questProgress", "requireID":"kaverin", "value":21 }] } , { "text":"4/4 kaverin:100  (Ol